!gradle/wrapper/gradle-wrapper.properties

# Compiled / packaged artifacts
*.class
*.jar
*.war
!gradle/wrapper/gradle-wrapper.jar

# Generated gRPC / Protobuf sources (regenerated by the build)
**/generated/

